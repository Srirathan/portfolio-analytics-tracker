# Copy to .env in this directory (backend/). Never commit real secrets.

# JWT signing. Also accepted: SECRET_KEY
# Local SQLite: any value works for class; use a long random string for real data.
# PostgreSQL (or any non-SQLite DATABASE_URL): must be a random string of at least 32 characters
# and must NOT be this placeholder or the dev default — the app will refuse to start otherwise.
JWT_SECRET_KEY=replace-with-a-long-random-string

# SQLite (default, file created in the current working directory when you start uvicorn from backend/)
# or PostgreSQL in production, e.g.:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=sqlite:///./portfolio_tracker.db

# Comma-separated browser origins for CORS (no spaces). Include every frontend URL you use.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional overrides (defaults are set in app code if omitted):
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# PRICE_API_URL=https://query1.finance.yahoo.com/v8/finance/chart
