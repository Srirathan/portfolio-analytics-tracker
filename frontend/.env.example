# Copy to .env in this directory (frontend/) only if you need overrides.

# --- Local development (npm run dev) ---
# The app calls /api/v1 on the Vite dev server; Vite proxies /api to the backend (vite.config.ts).
# You do not need VITE_API_BASE_URL unless you bypass the proxy.

# If the API is not on http://127.0.0.1:8080, point the dev proxy at it:
# VITE_DEV_API_ORIGIN=http://127.0.0.1:8765

# --- Production (npm run build / Vercel / static host) ---
# Required for a hosted frontend: full URL of the API including /api/v1 (no trailing slash).
# VITE_API_BASE_URL=https://your-api.example.com/api/v1
